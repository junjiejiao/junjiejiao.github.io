@Article{Jiao2020cssl,
  author   = {J. {Jiao} and H. L. {Trentelman} and M. K. {Camlibel}},
  title    = {Distributed Linear Quadratic Optimal Control: Compute Locally and Act Globally},
  journal  = {IEEE Control Systems Letters},
  year     = {2020},
  volume   = {4},
  number   = {1},
  pages    = {67-72},
  month    = {Jan},
  issn     = {2475-1456},
  abstract = {In this letter we consider the distributed linear quadratic (LQ) control problem for networks of agents with single integrator dynamics. We first establish a general formulation of the distributed LQ problem and show that the optimal control gain depends on global information on the network. Thus, the optimal protocol can only be computed in a centralized fashion. In order to overcome this drawback, we propose the design of protocols that are computed in a decentralized way. We will write the global cost functional as a sum of local cost functionals, each associated with one of the agents. In order to achieve “good” performance of the controlled network, each agent then computes its own local gain, using sampled information of its neighboring agents. This decentralized computation will only lead to suboptimal global network behavior. However, we will show that the resulting network will reach consensus.},
  doi      = {10.1109/LCSYS.2019.2922189},
  keywords = {control system synthesis;distributed control;linear quadratic control;optimisation;distributed linear quadratic optimal control;distributed linear quadratic control problem;LQ;single integrator dynamics;general formulation;optimal control gain;global information;optimal protocol;global cost functional;local cost functionals;controlled network;local gain;neighboring agents;decentralized computation;suboptimal global network behavior;resulting network;Optimal control;Protocols;Laplace equations;Artificial neural networks;Symmetric matrices;Knowledge engineering;Trajectory;Distributed control;linear quadratic optimal control;decentralized computation;consensus;multi-agent systems},
}

